#!/usr/bin/env bash
# bin/we — build-from-source wrapper for the legion (we) binary.
#
# Builds from ~/projects/legion (override with LEGION_REPO) and caches the
# binary at ~/.local/bin/we. Rebuilds on 'we upgrade'.
#
# Rationale: the v0.1.0 release tarball does not exist on GitHub, so the
# prior download-based wrapper was broken. Legion lives in a sibling repo
# and its own bin/we also builds from source — we follow the same model.
set -euo pipefail

BINARY="${HOME}/.local/bin/we"
LEGION_REPO="${LEGION_REPO:-${HOME}/projects/legion}"

_build() {
  if [ ! -d "${LEGION_REPO}" ]; then
    echo "we: ERROR: legion repo not found at ${LEGION_REPO}" >&2
    echo "we: Set LEGION_REPO to the path of the legion source checkout." >&2
    exit 1
  fi
  if [ ! -f "${LEGION_REPO}/go.mod" ]; then
    echo "we: ERROR: ${LEGION_REPO} is not a Go module (no go.mod)" >&2
    exit 1
  fi
  echo "we: building from ${LEGION_REPO} ..." >&2
  mkdir -p "$(dirname "${BINARY}")"
  # Prefer /usr/local/go/bin/go if PATH doesn't have go
  local go_bin="go"
  if ! command -v go >/dev/null 2>&1; then
    if [ -x /usr/local/go/bin/go ]; then
      go_bin=/usr/local/go/bin/go
    else
      echo "we: ERROR: go toolchain not found on PATH or at /usr/local/go/bin/go" >&2
      exit 1
    fi
  fi
  (cd "${LEGION_REPO}" && "${go_bin}" build -o "${BINARY}" ./cmd/we/)
  echo "we: built -> ${BINARY}" >&2
}

if [ "${1:-}" = "upgrade" ]; then
  _build
  exit 0
fi

if [ ! -x "${BINARY}" ]; then
  _build
fi

exec "${BINARY}" "$@"
